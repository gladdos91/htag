# --- Database ---
# Local Postgres example: postgresql://user:pass@localhost:5432/htag
# Railway/Fly.io will provide this for you when you provision Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/htag"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- Resend (newsletter delivery) ---
# Sign up at https://resend.com, verify your sending domain, paste the key
RESEND_API_KEY="re_xxxxxxxxxx"
NEWSLETTER_FROM_EMAIL="newsletter@hoffmantag.org"
NEWSLETTER_FROM_NAME="Hoffman Tenants Advocacy Group"

# --- Public site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
